# Supabase (Postgres storage for the inquiries table)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase anon/publishable key — used only for admin login sessions (/admin).
# Safe to expose to the browser; admin data reads/writes still go through the
# service-role client on the server, gated by the authenticated session.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Resend (transactional email: staff notification + submitter auto-reply)
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@rap-usvi.org
RESEND_STAFF_NOTIFY_TO=earl@nigc-llc.com,Elphillip@hotmail.com

# Cloudflare Turnstile (spam protection on the Stakeholder Inquiry form)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# PostHog (analytics)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Sentry (error monitoring)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# Salt used when hashing submitter IP addresses for rate limiting (never store raw IPs)
IP_HASH_SALT=

# Secret used to sign one-click unsubscribe links for bulk email campaigns
# (admin's Send Campaign feature). Set a real random value in production —
# the fallback baked into the code is a fixed, publicly-visible string.
EMAIL_UNSUBSCRIBE_SECRET=

# PayPal (one-time donations via Orders API v2)
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENV=sandbox
# From the PayPal Developer Dashboard after registering /api/donations/webhook
PAYPAL_WEBHOOK_ID=
