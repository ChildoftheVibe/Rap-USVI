# Supabase (Postgres storage for the inquiries table)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Resend (transactional email: staff notification + submitter auto-reply)
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@rap-usvi.org
RESEND_STAFF_NOTIFY_TO=earl@nigc-llc.com,Elphillip@hotmail.com

# Cloudflare Turnstile (spam protection on the Stakeholder Inquiry form)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# PostHog (analytics)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Sentry (error monitoring)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# Zeffy ("Join the Movement" signup embed — a public embed URL, not a secret)
NEXT_PUBLIC_ZEFFY_SIGNUP_EMBED_URL=

# Salt used when hashing submitter IP addresses for rate limiting (never store raw IPs)
IP_HASH_SALT=
